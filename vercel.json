{
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors 'self' http://localhost:3000 http://127.0.0.1:3000 https://websitewhisper.com https://www.websitewhisper.com"
          }
        ]
      }
    ]
  }
  